{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "powershell",
          "cmd": "powershell.exe",
          "args": true
        },
        {
          "name": "cmd",
          "cmd": "cmd.exe",
          "args": true
        },
        {
          "name": "wsl",
          "cmd": "wsl.exe",
          "args": true
        }
      ]
    }
  ]
}
